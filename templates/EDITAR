<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<style>
body{background:#0f172a;color:white;font-family:Arial;padding:20px;}
.box{background:#111827;padding:20px;border-radius:12px;width:400px;}
input{width:100%;padding:10px;margin:6px 0;background:#1f2937;color:white;border:none;border-radius:8px;}
button{width:100%;padding:12px;background:#22c55e;border:none;border-radius:8px;}
</style>
</head>

<body>

<h2>✏️ Editar OS {{ os.numero }}</h2>

<div class="box">
<form method="post">

<input name="cliente" value="{{ os.cliente }}">
<input name="aparelho" value="{{ os.aparelho }}">
<input name="defeito" value="{{ os.defeito }}">

<input name="valor" value="{{ os.valor }}">
<input name="custo" value="{{ os.custo }}">
<input name="frete" value="{{ os.frete }}">

<button>Salvar</button>

</form>
</div>

</body>
</html>
